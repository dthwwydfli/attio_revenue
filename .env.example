# =============================================================================
# LeadLoop — required for API startup (Layer 0 validates all of these)
# Copy to .env and fill in real values: cp .env.example .env
# =============================================================================

# Attio (required)
ATTIO_API_KEY=
ATTIO_WORKSPACE_SLUG=

# API (required)
PORT=3001
API_BASE_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# LLM — provide at least one (required)
OPENAI_API_KEY=
# GROQ_API_KEY=

# Enrichment — provide at least one (required)
TAVILY_API_KEY=
# SERPER_API_KEY=

# Superlinked SIE (required)
SIE_BASE_URL=http://localhost:8080
SIE_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
ICP_DESCRIPTION="B2B SaaS companies, 50-500 employees, US/EU, buying intent for CRM automation, VP Sales or RevOps leaders evaluating agentic CRM tools."

# SLNG (required)
SLNG_API_KEY=
SLNG_AGENT_ID=
SLNG_WEBHOOK_SECRET=

# n8n (optional)
N8N_WEBHOOK_SECRET=

# Aikido (GitHub secret — CI only)
AIKIDO_SECRET_KEY=

# Frontend (required — validated by API Layer 0)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_ATTIO_WORKSPACE_URL=https://app.attio.com/YOUR_WORKSPACE
