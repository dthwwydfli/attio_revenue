# =============================================================================
# LeadLoop — shared hackathon environment
# =============================================================================
# Quick start for teammates:
#   1. cp .env.example .env.local
#   2. cp .env.example .env
#   3. pnpm install
#   4. pnpm dev:api
#
# This file mirrors the working .env.local — shared team keys for the hackathon.
# For production, rotate keys and use a private .env.local (gitignored).
# =============================================================================

# -----------------------------------------------------------------------------
# Attio CRM — https://app.attio.com → Settings → Developers
# -----------------------------------------------------------------------------
