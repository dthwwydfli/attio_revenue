# -----------------------------------------------------------------------------
SIE_ENDPOINT=http://a64e1dc31032c40e4b1e9330a1273c83-1760332796.us-east-2.elb.amazonaws.com:8080
SIE_API_KEY=SL-13296bf4f86317244a6c6cef15e91f34
