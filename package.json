{
  "name": "leadloop",
  "private": true,
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "dev:api": "pnpm --filter @leadloop/api dev",
    "dev:web": "pnpm --filter @leadloop/web dev",
    "build:api": "pnpm --filter @leadloop/api build",
    "start:api": "pnpm --filter @leadloop/api start",
    "build": "pnpm run --filter @leadloop/shared build && pnpm run --parallel build",
    "typecheck": "pnpm run --parallel typecheck",
    "lint": "pnpm run --parallel lint"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
